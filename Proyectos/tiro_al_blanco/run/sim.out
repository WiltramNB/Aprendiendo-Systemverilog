    %vpi_call/w 3 14 "$display", "%16b | %b   | sin LED, win=0", v0000025eaaf0bea0_0, v0000025eaaf085c0_0 {0 0 0};
    %pushi/vec4 1, 0, 16;
    %store/vec4 v0000025eaaf0bea0_0, 0, 16;
    %delay 10, 0;
    %vpi_call/w 3 18 "$display", "%16b | %b   | LED 0, win=0", v0000025eaaf0bea0_0, v0000025eaaf085c0_0 {0 0 0};
    %pushi/vec4 128, 0, 16;
