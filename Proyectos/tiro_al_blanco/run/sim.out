    %delay 10, 0;
    %vpi_call/w 3 22 "$display", "%16b | %b   | LED 7, win=0", v0000025eaaf0bea0_0, v0000025eaaf085c0_0 {0 0 0};
    %pushi/vec4 256, 0, 16;
    %store/vec4 v0000025eaaf0bea0_0, 0, 16;
    %delay 10, 0;
    %vpi_call/w 3 26 "$display", "%16b | %b   | LED 8, win=1 !!!", v0000025eaaf0bea0_0, v0000025eaaf085c0_0 {0 0 0};
    %pushi/vec4 512, 0, 16;
